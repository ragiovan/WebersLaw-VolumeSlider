<Window x:Class="WeberSine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weber's Law — Sine Wave"
        Height="440" Width="520"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C2E">

    <Window.Resources>

        <!-- Base text style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Slider track -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#7C9EFF"/>
        </Style>

        <!-- Log/Linear toggle button -->
        <Style x:Key="ToggleStyle" TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Unchecked = Linear -->
            <Setter Property="Background" Value="#2E2E4E"/>
            <Setter Property="BorderBrush" Value="#5555AA"/>
            <Setter Property="Foreground" Value="#A0A0D0"/>
            <Setter Property="Content" Value="Linear"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#4040A0"/>
                    <Setter Property="BorderBrush" Value="#7C9EFF"/>
                    <Setter Property="Foreground" Value="#E0E8FF"/>
                    <Setter Property="Content" Value="Logarithmic"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Play / Pause button -->
        <Style x:Key="PlayStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1C1C2E"/>
            <Setter Property="Background" Value="#7C9EFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="36,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="22"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9BB0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5C7EDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Amplitude bar -->
        <Style x:Key="AmpBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="#2E2E4E"/>
            <Setter Property="Foreground" Value="#7C9EFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"/>
                            <Border x:Name="PART_Track" CornerRadius="6"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="6"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="36,32,36,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header          -->
            <RowDefinition Height="32"/>    <!-- spacer          -->
            <RowDefinition Height="Auto"/>  <!-- volume label    -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- slider          -->
            <RowDefinition Height="28"/>    <!-- spacer          -->
            <RowDefinition Height="Auto"/>  <!-- scale toggle    -->
            <RowDefinition Height="28"/>    <!-- spacer          -->
            <RowDefinition Height="Auto"/>  <!-- amp label row   -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- amp bar         -->
            <RowDefinition Height="*"/>     <!-- fill            -->
            <RowDefinition Height="Auto"/>  <!-- play button     -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Weber's Law" FontSize="26" FontWeight="Bold" Foreground="#7C9EFF"/>
            <TextBlock Text="440 Hz pure sine tone" FontSize="13" Foreground="#6060A0" Margin="2,4,0,0"/>
        </StackPanel>

        <!-- Volume label row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Volume" FontSize="13" FontWeight="SemiBold" Foreground="#A0A0D0" VerticalAlignment="Center"/>
            <TextBlock x:Name="SliderValueText" Grid.Column="1"
                       FontSize="13" Foreground="#6060A0" VerticalAlignment="Center" Text="50"/>
        </Grid>

        <!-- Slider -->
        <Slider Grid.Row="4"
                x:Name="VolumeSlider"
                Minimum="0" Maximum="100" Value="50"
                ValueChanged="VolumeSlider_ValueChanged"/>

        <!-- Scale toggle -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Volume scale" FontSize="13" FontWeight="SemiBold"
                       Foreground="#A0A0D0" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <ToggleButton x:Name="LogToggle"
                          Style="{StaticResource ToggleStyle}"
                          Checked="LogToggle_Changed"
                          Unchecked="LogToggle_Changed"/>
        </StackPanel>

        <!-- Linear amplitude label row -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Linear amplitude" FontSize="13" FontWeight="SemiBold"
                       Foreground="#A0A0D0" VerticalAlignment="Center"/>
            <TextBlock x:Name="LinearValueText" Grid.Column="1"
                       FontSize="13" Foreground="#7C9EFF" VerticalAlignment="Center" Text="0.5000"/>
        </Grid>

        <!-- Amplitude progress bar -->
        <ProgressBar Grid.Row="10"
                     x:Name="LinearBar"
                     Style="{StaticResource AmpBarStyle}"
                     Minimum="0" Maximum="1" Value="0.5"/>

        <!-- Play / Pause button -->
        <Button Grid.Row="12"
                x:Name="PlayStopButton"
                Style="{StaticResource PlayStyle}"
                Content="&#x25B6;  Play"
                HorizontalAlignment="Center"
                Click="PlayStopButton_Click"/>

    </Grid>
</Window>
